# Supabase — required on Vercel (HTTPS; avoids ENOTFOUND on db.* host)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_from_supabase_api_settings

# Optional: direct Postgres (local dev). Use port 6543 for Supabase pooler on same host.
# DATABASE_URL=postgresql://postgres:password@db.your-ref.supabase.co:6543/postgres

NEXT_PUBLIC_APP_NAME=UAE Property SaaS
DEMO_USER_ID=22222222-2222-2222-2222-222222222201
